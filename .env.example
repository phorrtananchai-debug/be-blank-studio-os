VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_ALLOWED_STUDIO_EMAIL=studio@example.com

# Google Corebase read-only endpoint (Apps Script Web App URL).
# Leave blank to keep BE BLANK OS in mock mode.
# Set to your Apps Script Web App URL to enable google-readonly mode.
# Never commit sensitive/private production endpoint values.
VITE_GOOGLE_COREBASE_ENDPOINT=

# Corebase mode selector.
# - mock: force local/mock mode
# - google-readonly: read-only Apps Script resources
# - karun-live-control: Karun Phuket scoped live-control (read/write safe patch actions only)
# If endpoint is blank, mode safely falls back to mock.
VITE_GOOGLE_COREBASE_MODE=
